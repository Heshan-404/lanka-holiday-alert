# Sri Lanka HolidaySync - Configuration Example

# 1. Get your API Key from: https://calendarific.com/signup
CALENDARIFIC_API_KEY=your_api_key_here

# 2. Slack Webhooks (Comma-separated)
# How to get: Slack App > Incoming Webhooks > Add New Webhook to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXX/BXXX/XXXX

# 3. Discord Webhooks (Comma-separated)
# How to get: Channel Settings > Integrations > Webhooks > Create / Copy Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/XXXX

# 4. Security (A random string to protect your public Vercel endpoint)
CRON_SECRET=generate_a_random_string_here

# 5. Advanced Customization
# The day of the month when the "Next Month" report is sent.
REPORT_SCHEDULE_DAY=10

# Holiday types to include (Comma-separated).
# Available types in Sri Lanka: 
# - national holiday, public holiday, bank holiday, observance, season
HOLIDAY_TYPES=public holiday, national holiday
